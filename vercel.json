{
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|gif|svg|css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "http://markode.co/:path*",
      "destination": "https://markode.co/:path*",
      "permanent": true
    },
    {
      "source": "https://www.markode.co/:path*",
      "destination": "https://markode.co/:path*",
      "permanent": true
    },
    {
      "source": "http://www.markode.co/:path*",
      "destination": "https://markode.co/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ]
}
